-- ═══════════════════════════════════════════════════════════════
-- APO.YA — Schema de Supabase
-- Ejecuta este SQL en: Supabase → SQL Editor → New Query
-- ═══════════════════════════════════════════════════════════════

-- ── Tabla de centros de refugio ─────────────────────────────────
CREATE TABLE IF NOT EXISTS centers (
  id                BIGSERIAL PRIMARY KEY,
  nombre            TEXT NOT NULL,
  direccion         TEXT,
  telefono          TEXT,
  estado            TEXT,
  municipio         TEXT,
  horario           TEXT,
  foto_url          TEXT,
  maps_url          TEXT,
  insumos_requeridos TEXT[],
  inventario        JSONB DEFAULT '{}',
  status            TEXT DEFAULT 'critico' CHECK (status IN ('critico', 'moderado', 'full')),
  ultimo_reporte    TIMESTAMPTZ,
  ultimo_mensaje    TEXT,
  verificado        BOOLEAN DEFAULT FALSE,
  creado_en         TIMESTAMPTZ DEFAULT NOW()
);

-- ── Tabla de mensajes de Telegram ───────────────────────────────
CREATE TABLE IF NOT EXISTS mensajes_telegram (
  id                  BIGSERIAL PRIMARY KEY,
  telegram_message_id BIGINT,
  from_name           TEXT,
  text                TEXT,
  has_photo           BOOLEAN DEFAULT FALSE,
  tipo                TEXT CHECK (tipo IN ('NECESIDAD', 'DONACION', 'IRRELEVANTE')),
  centro_mencionado   TEXT,
  insumos             TEXT[],
  cantidades          JSONB DEFAULT '{}',
  confianza           TEXT CHECK (confianza IN ('alta', 'media', 'baja')),
  timestamp           TIMESTAMPTZ,
  raw                 TEXT,
  procesado_en        TIMESTAMPTZ DEFAULT NOW()
);

-- ── Índices ──────────────────────────────────────────────────────
CREATE INDEX IF NOT EXISTS idx_centers_status ON centers(status);
CREATE INDEX IF NOT EXISTS idx_centers_estado ON centers(estado);
CREATE INDEX IF NOT EXISTS idx_mensajes_tipo ON mensajes_telegram(tipo);
CREATE INDEX IF NOT EXISTS idx_mensajes_centro ON mensajes_telegram(centro_mencionado);
CREATE INDEX IF NOT EXISTS idx_mensajes_timestamp ON mensajes_telegram(timestamp DESC);

-- ── Row Level Security (RLS) — lectura pública, escritura solo API ──
ALTER TABLE centers ENABLE ROW LEVEL SECURITY;
ALTER TABLE mensajes_telegram ENABLE ROW LEVEL SECURITY;

-- Cualquiera puede leer centros (el dashboard es público)
CREATE POLICY "centros_lectura_publica"
  ON centers FOR SELECT USING (true);

-- Solo service_role puede escribir (el webhook de Vercel usa service_role)
CREATE POLICY "centros_escritura_service"
  ON centers FOR ALL USING (auth.role() = 'service_role');

CREATE POLICY "mensajes_lectura_publica"
  ON mensajes_telegram FOR SELECT USING (true);

CREATE POLICY "mensajes_escritura_service"
  ON mensajes_telegram FOR ALL USING (auth.role() = 'service_role');

